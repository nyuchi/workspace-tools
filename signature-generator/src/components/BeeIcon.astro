---
/**
 * BeeIcon — the "nyuchi" (bee in Shona) brand mark. Fixed brand colors
 * (gold body #FFD740, baobab-brown detail #5D4037) — this is a logo, not
 * a themed illustration, so it intentionally does not follow the theme.
 */
interface Props {
  class?: string
}

const { class: className = 'h-6 w-6' } = Astro.props
---

<svg class={className} viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <ellipse cx="12" cy="13" rx="6" ry="5" fill="#FFD740"></ellipse>
  <path d="M8 11.5h8M8 13.5h8M8 15.5h8" stroke="#5D4037" stroke-width="1.5" stroke-linecap="round"></path>
  <circle cx="12" cy="7" r="3" fill="#5D4037"></circle>
  <circle cx="10.5" cy="6.5" r="0.75" fill="#FFD740"></circle>
  <circle cx="13.5" cy="6.5" r="0.75" fill="#FFD740"></circle>
  <path d="M10 4.5C9 3 8 2.5 7.5 2.5M14 4.5C15 3 16 2.5 16.5 2.5" stroke="#5D4037" stroke-width="1" stroke-linecap="round"></path>
  <ellipse cx="7" cy="10" rx="3" ry="2" fill="#5D4037" fill-opacity="0.2"></ellipse>
  <ellipse cx="17" cy="10" rx="3" ry="2" fill="#5D4037" fill-opacity="0.2"></ellipse>
  <path d="M12 18v2" stroke="#5D4037" stroke-width="1.5" stroke-linecap="round"></path>
</svg>

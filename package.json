{
  "name": "workspace-tools",
  "version": "2.0.0",
  "description": "Nyuchi workspace tools - Gmail Add-on, email signature generator, Nyuchi Studio, and the nyuchi-tools Cloudflare Worker (SPA + MCP)",
  "private": true,
  "workspaces": [
    "gmail-addon",
    "email-signature"
  ],
  "scripts": {
    "push:gmail": "cd gmail-addon && clasp push",
    "push:signature": "cd email-signature && clasp push",
    "push:all": "npm run push:gmail && npm run push:signature",
    "open:gmail": "cd gmail-addon && clasp open",
    "open:signature": "cd email-signature && clasp open",
    "deploy:gmail": "cd gmail-addon && clasp deploy",
    "deploy:signature": "cd email-signature && clasp deploy",
    "build:web": "npm run build --prefix signature-generator",
    "dev:tools": "wrangler dev",
    "deploy:tools": "wrangler deploy",
    "typecheck:worker": "tsc --noEmit -p mcp/tsconfig.json",
    "test": "npm --prefix signature-generator test && npm run test:worker",
    "test:worker": "vitest run -c vitest.worker.config.ts"
  },
  "keywords": [
    "google-workspace",
    "gmail-addon",
    "email-signature",
    "admin-dashboard",
    "nyuchi",
    "nyuchi-africa"
  ],
  "author": {
    "name": "Nyuchi Web Services",
    "url": "https://services.nyuchi.com"
  },
  "contributors": [
    {
      "name": "Bryan Fawcett",
      "email": "bryan@nyuchi.com"
    }
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyuchitech/workspace-tools.git"
  },
  "bugs": {
    "url": "https://github.com/nyuchitech/workspace-tools/issues"
  },
  "homepage": "https://github.com/nyuchitech/workspace-tools#readme",
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.28",
    "jose": "^6.2.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^2.0.11",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.0.0"
  }
}
